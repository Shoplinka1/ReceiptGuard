{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_24"]
        },
        "install": {
          "cmds": ["corepack enable", "corepack prepare pnpm@10.26.1 --activate", "pnpm install --frozen-lockfile"]
        },
        "build": {
          "cmds": ["pnpm run build"]
        }
      }
    }
  }
}

# ReceiptGuard — Frontend Environment Variables
# Copy to .env.local for local development.
# For Vercel, set these under Project Settings → Environment Variables.

# ── Supabase ────────────────────────────────────────────────────────────────
# Found in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── API Base URL ─────────────────────────────────────────────────────────────
# Leave empty for Vercel (vercel.json rewrites /api/* to Railway server-side).
# Set to the Railway URL for local dev pointing at production backend:
#   VITE_API_URL=https://workspaceapi-server-production-1c35.up.railway.app
# Or leave blank to use the local dev server (default).
VITE_API_URL=

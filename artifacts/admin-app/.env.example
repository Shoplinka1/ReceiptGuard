# ReceiptGuard Admin App — Vercel Environment Variables
# Set these under Vercel → Project Settings → Environment Variables.
# Use the SAME values as the main receipt-guard app — both apps share
# the same Supabase project and Railway backend.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── API Base URL ──────────────────────────────────────────────────────────────
# Must be empty — vercel.json rewrites /api/* to Railway server-side.
VITE_API_URL=

# ── Login note ────────────────────────────────────────────────────────────────
# Sign in with the Google account that has is_admin=true in Supabase.
# Email+password login only works if a password was also set in Supabase Auth.
# If you signed up via Google, use "Sign in with Google" on the login page.
